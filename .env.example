# API keys (at least one required)
OPENAI_API_KEY=your_openai_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Access control
SITE_ACCESS_CODE=
ALLOW_USER_SUPPLIED_KEYS=false

# Safety limits
MAX_UPLOAD_MB=20
MAX_SOURCE_CHARS=120000
MAX_BLOCK_COUNT=400
MAX_REPORT_ROWS=400
MIN_SECONDS_BETWEEN_JOBS=30
DAILY_REQUEST_LIMIT=80

# Order / payment verification
ADMIN_REVIEW_CODE=change_me_admin_code
WECHAT_PAY_QR_URL=
ALIPAY_PAY_QR_URL=
ORDER_DB_PATH=/tmp/sci_ssci_orders.db

# Future gateway auto-verification params (reserved)
WECHAT_MCH_ID=
WECHAT_APP_ID=
WECHAT_API_V3_KEY=
WECHAT_MCH_SERIAL_NO=
WECHAT_PRIVATE_KEY_PATH=
ALIPAY_APP_ID=
ALIPAY_APP_PRIVATE_KEY_PATH=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_VERIFY_MODE=sign

# Model pricing rules (CNY): unit / 1000字 and min fee
PRICE_GPT_3_5_TURBO_PER_1K=4
PRICE_GPT_3_5_TURBO_MIN=19
PRICE_DEEPSEEK_CHAT_PER_1K=5
PRICE_DEEPSEEK_CHAT_MIN=25
PRICE_GPT_4O_MINI_PER_1K=7
PRICE_GPT_4O_MINI_MIN=29
PRICE_DEEPSEEK_REASONER_PER_1K=10
PRICE_DEEPSEEK_REASONER_MIN=45
PRICE_GPT_4O_PER_1K=16
PRICE_GPT_4O_MIN=69
